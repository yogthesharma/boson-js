{
  "name": "@getboson/client",
  "version": "5.1.0",
  "description": "Boson API client (compat wrapper around @langfuse/client)",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "author": "Boson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yogthesharma/boson.git",
    "directory": "packages/getboson-client"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@langfuse/client": "workspace:^"
  }
}
